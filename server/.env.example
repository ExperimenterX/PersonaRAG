# Env file for server application

OPENAI_API_KEY=your api key here
OPENAI_MODEL=gpt-4.1-mini

# Optional Apple CLaRA integration (HTTP service adapter)
# If enabled and endpoint is reachable, generation uses CLaRA first,
# then falls back to OpenAI-based generation on errors.
CLARA_ENABLED=false
# If true, generator never falls back to OpenAI when CLaRA fails.
CLARA_STRICT=false
CLARA_ENDPOINT=http://localhost:9000
CLARA_TIMEOUT_SECONDS=30
CLARA_COMPRESSION_RATE=32
CLARA_PROVIDER=huggingface
CLARA_HF_MODEL=apple/CLaRa-7B-Instruct
# Required for gated/private HF models (including many Apple model endpoints).
HF_TOKEN=